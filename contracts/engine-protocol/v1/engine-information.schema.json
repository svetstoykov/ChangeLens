{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changelens.dev/contracts/engine-protocol/v1/engine-information.schema.json",
  "title": "ChangeLens engine information exchange",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/result" },
    { "$ref": "#/$defs/errorResponse" }
  ],
  "$defs": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "requestId", "method"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "requestId": { "type": "string", "minLength": 1 },
        "method": { "const": "engine.getInfo" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "requestId", "result"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "result" },
        "requestId": { "type": "string", "minLength": 1 },
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "protocolVersion"],
          "properties": {
            "name": { "const": "ChangeLens.Engine" },
            "version": { "type": "string", "minLength": 1 },
            "protocolVersion": { "const": 1 }
          }
        }
      }
    },
    "errorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "requestId", "error"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "error" },
        "requestId": { "type": ["string", "null"] },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "code", "message"],
          "properties": {
            "type": {
              "enum": [
                "NotFound",
                "Validation",
                "MalformedInput",
                "UnprocessableInput",
                "Conflict",
                "InvalidOperation",
                "Unauthorized",
                "Timeout",
                "ExternalDependencyFailure",
                "InternalError"
              ]
            },
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
