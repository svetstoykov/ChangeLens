{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changelens.dev/contracts/engine-protocol/v1/engine-status.schema.json",
  "title": "ChangeLens engine status exchange",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    {
      "$ref": "https://changelens.dev/contracts/engine-protocol/v1/payload-free-result.schema.json"
    },
    {
      "$ref": "https://changelens.dev/contracts/engine-protocol/v1/error-response.schema.json"
    }
  ],
  "$defs": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "requestId", "action"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "requestId": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "action": { "const": "engine.checkStatus" }
      }
    }
  }
}
