{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changelens.dev/contracts/engine-protocol/v1/error-response.schema.json",
  "title": "ChangeLens engine protocol error response",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocolVersion", "type", "requestId", "errors"],
  "properties": {
    "protocolVersion": { "const": 1 },
    "type": { "const": "error" },
    "requestId": { "type": ["string", "null"], "minLength": 1 },
    "errors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/operationError" }
    }
  },
  "$defs": {
    "operationError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "code", "message"],
      "properties": {
        "type": {
          "enum": [
            "NotFound",
            "Validation",
            "MalformedInput",
            "UnprocessableInput",
            "Conflict",
            "InvalidOperation",
            "Unauthorized",
            "Timeout",
            "ExternalDependencyFailure",
            "InternalError"
          ]
        },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
