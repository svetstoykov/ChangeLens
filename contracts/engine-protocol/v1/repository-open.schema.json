{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changelens.dev/contracts/engine-protocol/v1/repository-open.schema.json",
  "title": "ChangeLens repository-open exchange",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/branchResult" },
    { "$ref": "#/$defs/detachedResult" },
    { "$ref": "https://changelens.dev/contracts/engine-protocol/v1/error-response.schema.json" }
  ],
  "$defs": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "requestId", "action", "parameters"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "requestId": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "action": { "const": "repositories.open" },
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1,
              "maxLength": 8192,
              "pattern": "^(?=.*\\S)[^\\u0000]+$"
            }
          }
        }
      }
    },
    "repositoryBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "canonicalPath", "head"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "canonicalPath": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "head": {}
      }
    },
    "branchHead": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "revision"],
      "properties": {
        "kind": { "const": "branch" },
        "name": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "revision": { "$ref": "#/$defs/revision" }
      }
    },
    "detachedHead": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "revision"],
      "properties": {
        "kind": { "const": "detached" },
        "revision": { "$ref": "#/$defs/revision" }
      }
    },
    "revision": {
      "type": "string",
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
    },
    "branchResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "requestId", "result"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "result" },
        "requestId": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository"],
          "properties": {
            "repository": {
              "allOf": [
                { "$ref": "#/$defs/repositoryBase" },
                { "properties": { "head": { "$ref": "#/$defs/branchHead" } } }
              ]
            }
          }
        }
      }
    },
    "detachedResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "requestId", "result"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "result" },
        "requestId": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository"],
          "properties": {
            "repository": {
              "allOf": [
                { "$ref": "#/$defs/repositoryBase" },
                { "properties": { "head": { "$ref": "#/$defs/detachedHead" } } }
              ]
            }
          }
        }
      }
    }
  }
}
