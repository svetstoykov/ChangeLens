{
  "name": "@changelens/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "format": "prettier --write . ../README.md ../package.json ../scripts ../../../eslint.config.mjs ../../../tests/unit/desktop --config ../../../.prettierrc.json --ignore-path ../../../.prettierignore",
    "format:check": "prettier --check . ../README.md ../package.json ../scripts ../../../eslint.config.mjs ../../../tests/unit/desktop --config ../../../.prettierrc.json --ignore-path ../../../.prettierignore",
    "lint": "node ../scripts/lint.mjs",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@tauri-apps/api": "2.11.1",
    "monaco-editor": "0.56.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
